# ==========================================
# CONFIGURAÇÕES DO DJANGO (GERAIS)
# ==========================================

# ATENÇÃO: Nunca comite o arquivo .env com a sua SECRET_KEY de produção real!
# Gere uma chave de 50+ caracteres:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=sua-chave-secreta-em-producao-longa-e-segura

# Em produção, DEVE ser False!
DJANGO_DEBUG=False

# Domínios permitidos (separados por vírgula). Ex: seudominio.com.br,www.seudominio.com.br
# Para validação via túnel SSH no droplet, basta localhost.
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens confiáveis para CSRF (com esquema http/https). Túnel local:
CSRF_TRUSTED_ORIGINS=http://localhost:8003


# ==========================================
# BANCO DE DADOS (PostgreSQL Managed - DigitalOcean)
# ==========================================
# Database dedicado do IFEM, acessado pela role ifem_app. sslmode=require é obrigatório.
# Se a variável não for definida, o projeto cai no SQLite local (desenvolvimento).
DATABASE_URL=postgresql://ifem_app:SENHA_AQUI@fnp-database-do-user-37776190-0.k.db.ondigitalocean.com:25060/ifem?sslmode=require


# ==========================================
# SEGURANÇA (HTTPS)
# ==========================================

# Se a hospedagem já estiver servindo HTTPS (ex: Nginx+TLS, Render) mude para True.
# Enquanto o acesso for por túnel SSH/HTTP, mantenha False.
SECURE_SSL_REDIRECT=False


# ==========================================
# MAPBOX
# ==========================================
MAPBOX_PUBLIC_TOKEN=seu_token_publico_do_mapbox


# ==========================================
# GUNICORN (container Docker)
# ==========================================
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
# Rodar migrações automaticamente no start do container (1=sim, 0=não).
RUN_MIGRATIONS=1
